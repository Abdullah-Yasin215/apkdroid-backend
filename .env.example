# APKDroid Backend Configuration
# Copy this to .env and fill in your actual values

# ==================== Database ====================
DATABASE_URL=postgresql://user:password@localhost:5432/apkdroid

# ==================== Redis (Caching) ====================
REDIS_URL=redis://localhost:6379

# ==================== Application ====================
SECRET_KEY=your-super-secret-key-change-this-in-production
APP_NAME=APKDroid
APP_VERSION=1.0.0

# ==================== CORS & Security ====================
ALLOWED_ORIGINS=http://localhost:3000,https://apkdroid.net,https://www.apkdroid.net

# ==================== VirusTotal Integration ====================
# Get API key from: https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=your-virustotal-api-key-here
ENABLE_VIRUS_SCANNING=true

# ==================== Download Sources ====================
# Priority order for finding download links
PREFERRED_DOWNLOAD_SOURCES=f_droid,apkmirror,apkpure
ENABLE_AFFILIATE_LINKS=true

# ==================== Download Page ====================
# Countdown timer for download page (improves ad impressions)
ENABLE_DOWNLOAD_REDIRECT=true
DOWNLOAD_REDIRECT_TIMEOUT_SECONDS=5

# ==================== Content & Reviews ====================
ENABLE_USER_REVIEWS=true
MAX_REVIEWS_PER_APP=100

# ==================== SEO ====================
SITE_URL=https://apkdroid.net
ROBOTS_TXT_PATH=/robots.txt
SITEMAP_CHUNK_SIZE=50000

# ==================== Scraper Settings ====================
SCRAPER_DELAY=2
APPS_PER_SCRAPE_RUN=100

# ==================== Google AdSense ====================
GOOGLE_ADSENSE_PUBLISHER_ID=ca-pub-XXXXXXXXXXXXXXXX

# ==================== Email ====================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
ADMIN_EMAIL=admin@apkdroid.net

# ==================== Logging ====================
LOG_LEVEL=INFO

# Scraper Settings
SCRAPER_DELAY=0.3
APPS_PER_SCRAPE_RUN=10000
